@model BREW_POS.Models.User

<h2>Tambah User</h2>

<form asp-action="Create">

    <div>
        <label>Username</label>
        <input asp-for="Username" />
    </div>

    <div>
        <label>Full Name</label>
        <input asp-for="FullName" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="PasswordHash" />
    </div>

    <div>
        <label>Role</label>
        <select asp-for="Role">
            <option>Admin</option>
            <option>Kasir</option>
        </select>
    </div>

    <button type="submit">
        Simpan
    </button>

</form>