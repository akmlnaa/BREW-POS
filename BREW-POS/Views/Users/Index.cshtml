@model IEnumerable<BREW_POS.Models.User>

<h2>Daftar User</h2>

<a href="/Users/Create">Tambah User</a>

<table border="1">
    <thead>
        <tr>
            <th>Username</th>
            <th>Full Name</th>
            <th>Role</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Username</td>
                <td>@item.FullName</td>
                <td>@item.Role</td>
            </tr>
        }
    </tbody>
</table>