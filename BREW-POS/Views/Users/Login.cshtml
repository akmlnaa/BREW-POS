@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - BREW POS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: radial-gradient(circle at top left, rgba(139, 94, 60, .22), transparent 35%), radial-gradient(circle at bottom right, rgba(31, 41, 55, .14), transparent 35%), #f5f0e8;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 420px;
            background: rgba(255, 255, 255, .78);
            border: 1px solid rgba(255, 255, 255, .9);
            border-radius: 32px;
            padding: 46px 42px;
            box-shadow: 0 30px 80px rgba(92, 64, 39, .18);
            backdrop-filter: blur(18px);
        }

        .brand {
            text-align: center;
            margin-bottom: 34px;
        }

            .brand h1 {
                font-size: 42px;
                font-weight: 900;
                letter-spacing: -1px;
                margin-bottom: 6px;
                color: #1f2937;
            }

                .brand h1 span {
                    color: #8b5e3c;
                }

            .brand p {
                margin: 0;
                font-size: 13px;
                font-weight: 700;
                letter-spacing: 3px;
                color: #9b6a3d;
                text-transform: uppercase;
            }

        .welcome {
            text-align: center;
            margin-bottom: 28px;
        }

            .welcome h3 {
                font-weight: 800;
                color: #1f2937;
                margin-bottom: 8px;
            }

            .welcome small {
                color: #6b7280;
            }

        .form-label {
            font-weight: 700;
            color: #374151;
            font-size: 14px;
        }

        .form-control {
            height: 48px;
            border-radius: 14px;
            border: 1px solid #e3d8ca;
            background: rgba(255,255,255,.8);
        }

            .form-control:focus {
                border-color: #8b5e3c;
                box-shadow: 0 0 0 .2rem rgba(139, 94, 60, .15);
            }

        .btn-login {
            height: 50px;
            border: none;
            border-radius: 16px;
            background: #1f2937;
            color: white;
            font-weight: 800;
            margin-top: 10px;
            transition: .25s;
        }

            .btn-login:hover {
                background: #8b5e3c;
                transform: translateY(-2px);
            }

        .error-box {
            background: #fee2e2;
            color: #991b1b;
            border-radius: 14px;
            padding: 12px 14px;
            font-size: 14px;
            margin-bottom: 18px;
            text-align: center;
        }

        .login-footer {
            margin-top: 26px;
            text-align: center;
            color: #9ca3af;
            font-size: 13px;
        }
    </style>
</head>

<body>

    <div class="login-card">

        <div class="brand">
            <h1>BREW <span>POS</span></h1>
            <p>Building Reliable E-Web</p>
        </div>

        <div class="welcome">
            <h3>Welcome Back ☕</h3>
            <small>Login untuk masuk ke sistem kasir</small>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box">
                @ViewBag.Error
            </div>
        }

        <form asp-action="Login" method="post">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input name="username"
                       class="form-control"
                       autocomplete="off"
                       placeholder="Masukkan username" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input name="password"
                       type="password"
                       class="form-control"
                       placeholder="Masukkan password" />
            </div>

            <button type="submit"
                    class="btn-login w-100">
                Login to System
            </button>

        </form>

        <div class="login-footer">
            BREW POS © 2026
        </div>

    </div>

</body>
</html>