<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />

    <title>BREW POS Admin</title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <style>

        body {
            background: #f5f7fb;
            font-family: 'Segoe UI';
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            background: #111827;
            color: white;
            padding: 25px 20px;
        }

            .sidebar h3 {
                font-weight: bold;
                margin-bottom: 35px;
            }

            .sidebar a {
                display: block;
                color: #d1d5db;
                text-decoration: none;
                padding: 12px 15px;
                border-radius: 10px;
                margin-bottom: 10px;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background: #1f2937;
                    color: white;
                }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

    </style>

</head>

<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <h3>BREW POS</h3>

        <a href="/Admin/Dashboard">
            📊 Dashboard
        </a>

        <a href="/Admin/Users">
            👥 User Management
        </a>

        <a href="/Admin/Menus">
            ☕ Menu Management
        </a>

        <a href="/Admin/ProductSalesReport">
            ☕ Product Sales
        </a>

        <a href="/Admin/ShiftHistory">
            🕒 Shift History
        </a>

        <a href="/Admin/SalesReport">
            🧾 Transaction History
        </a>

        <a href="#"
           data-bs-toggle="modal"
           data-bs-target="#logoutModal">
            🚪 Logout
        </a>

    </div>

    <!-- CONTENT -->

    <div class="content">

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <div class="modal fade"
         id="logoutModal"
         tabindex="-1">

        <div class="modal-dialog modal-sm modal-dialog-centered">

            <div class="modal-content border-0 shadow-lg">

                <div class="modal-body text-center p-4">

                    <div style="font-size:52px;">
                        🚪
                    </div>

                    <h5 class="fw-bold mt-3">
                        Logout?
                    </h5>

                    <p class="text-muted mb-4">
                        Apakah kamu yakin ingin keluar dari sistem?
                    </p>

                    <div class="d-flex gap-2 justify-content-center">

                        <button type="button"
                                class="btn btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Batal
                        </button>

                        <a href="/Users/Login"
                           class="btn btn-dark">
                            Ya, Logout
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>
</body>
</html>