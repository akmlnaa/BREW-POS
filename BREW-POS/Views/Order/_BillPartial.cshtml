@model BREW_POS.Models.Bill

@if (Model == null)
{
    <p>Belum ada bill aktif</p>
}
else
{
    <div class="mb-3">

        <h5>🧾 @Model.BillName</h5>

        <small class="text-muted">
            Bill #@Model.BillId
        </small>

    </div>

    <hr />

    @if (Model.BillDetails.Any())
    {
        @foreach (var item in Model.BillDetails)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">

                <div>
                    <strong>@item.Menu.MenuName</strong><br />
                    <small>
                        @item.Qty x Rp @item.Price
                    </small>
                </div>

                <div class="text-end">

                    <div>
                        Rp @item.Subtotal
                    </div>

                    <form asp-action="RemoveItem" method="post">

                        <input type="hidden"
                               name="id"
                               value="@item.BillDetailId" />

                        <button class="btn btn-sm btn-danger mt-1">
                            ❌
                        </button>

                    </form>

                </div>

            </div>

            <hr />
        }

        <h5 class="mt-3">
            Total: Rp @Model.SubTotal
        </h5>

        <a href="/Order/PayBill/@Model.BillId"
           class="btn btn-dark w-100 mt-3">
            💰 Bayar Sekarang
        </a>
    }
    else
    {
        <p>Belum ada item</p>
    }
}