@model List<BREW_POS.Models.CartItem>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-muted py-4">

        <h5>🛒</h5>

        <p>Cart masih kosong</p>

    </div>
}
else
{
    decimal total = 0;

    @foreach (var item in Model)
    {
        total += item.Subtotal;

        <div class="card mb-2 border-0 shadow-sm">

            <div class="card-body p-2">

                <div class="d-flex justify-content-between">

                    <div>

                        <strong>
                            @item.MenuName
                        </strong>

                        <br />

                        <small class="text-muted">
                            Rp @item.Price
                        </small>

                    </div>

                    <div class="text-end">

                        <div class="fw-bold">
                            Rp @item.Subtotal
                        </div>

                    </div>

                </div>

                <!-- QTY CONTROL -->

                <div class="d-flex align-items-center gap-2 mt-2">

                    <form asp-action="DecreaseCartItem"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@item.MenuId" />

                        <button class="btn btn-sm btn-outline-dark">
                            -
                        </button>

                    </form>

                    <span class="fw-bold">
                        @item.Qty
                    </span>

                    <form asp-action="IncreaseCartItem"
                          method="post">

                        <input type="hidden"
                               name="id"
                               value="@item.MenuId" />

                        <button class="btn btn-sm btn-outline-dark">
                            +
                        </button>

                    </form>

                    <form asp-action="RemoveCartItem"
                          method="post"
                          class="ms-auto">

                        <input type="hidden"
                               name="id"
                               value="@item.MenuId" />

                        <button class="btn btn-sm btn-danger">
                            ❌
                        </button>

                    </form>

                </div>

                <!-- NOTE -->

                <form asp-action="UpdateCartNote"
                      method="post"
                      class="mt-2">

                    <input type="hidden"
                           name="id"
                           value="@item.MenuId" />

                    <input type="text"
                           name="note"
                           value="@item.Note"
                           placeholder="Tambah note..."
                           class="form-control form-control-sm" />

                </form>

            </div>

        </div>
    }

    decimal tax = total * 0.10m;
    decimal grandTotal = total + tax;

<hr />

<div class="d-flex justify-content-between mb-1">

    <span>Subtotal</span>

    <span>
        Rp @total
    </span>

</div>

<div class="d-flex justify-content-between mb-1">

    <span>Tax 10%</span>

    <span>
        Rp @tax
    </span>

</div>

<hr />

<div class="d-flex justify-content-between">

    <h5>Grand Total</h5>

    <h5 class="fw-bold">
        Rp @grandTotal
    </h5>

</div>
}