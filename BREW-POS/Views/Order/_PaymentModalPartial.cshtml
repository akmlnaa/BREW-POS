@model List<BREW_POS.Models.CartItem>

@{
    decimal subtotal = Model.Sum(x => x.Subtotal);
    decimal tax = subtotal * 0.10m;
    decimal grandTotal = subtotal + tax;
}

@if (!Model.Any())
{
    <div class="text-center text-muted py-4">
        Cart kosong
    </div>
}
else
{
    <div class="text-center mb-4 py-3"
         style="background:#f9fafb;border-radius:18px;">

        <h6 class="text-muted mb-1">
            Total Pembayaran
        </h6>

        <div class="d-flex justify-content-between mb-1">
            <span>Subtotal</span>
            <strong>Rp @subtotal.ToString("N0")</strong>
        </div>

        <div class="d-flex justify-content-between mb-2">
            <span>Tax 10%</span>
            <strong>Rp @tax.ToString("N0")</strong>
        </div>

        <hr />

        <h1 class="fw-bold display-5">
            Rp @grandTotal.ToString("N0")
        </h1>

    </div>

    <form id="paymentForm">

        <input type="hidden"
               name="BillId"
               value="@ViewBag.BillId" />

        <!-- PAYMENT METHOD -->

        <div class="mb-3">

            <label class="form-label fw-bold">
                Metode Pembayaran
            </label>

            <select name="PaymentMethod"
                    id="paymentMethod"
                    class="form-select">

                <option value="Cash">Cash</option>
                <option value="QRIS">QRIS</option>
                <option value="Debit">Debit Card</option>
                <option value="E-Wallet">E-Wallet</option>

            </select>

        </div>

        <!-- CASH AREA -->

        <div class="mb-3"
             id="cashArea">

            <label class="form-label fw-bold">
                Nominal Bayar
            </label>

            <input type="number"
                   id="cashInput"
                   name="Cash"
                   class="form-control form-control-lg"
                   placeholder="Masukkan uang..."
                   value="0" />

        </div>

        <!-- CHANGE -->

        <div class="card border-0 mb-3"
             style="background:#ecfdf5;">

            <div class="card-body text-center">

                <small class="text-muted">
                    Kembalian
                </small>

                <h3 class="fw-bold text-success"
                    id="changeText">

                    Rp 0

                </h3>

            </div>

        </div>

        <button type="submit"
                class="btn btn-success btn-lg w-100">

            💳 Bayar Sekarang

        </button>

    </form>
}