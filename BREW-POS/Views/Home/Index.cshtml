@{
    Layout = "_Layout";
}

<style>
    body {
        background: radial-gradient(circle at top left, rgba(173, 125, 78, .18), transparent 35%), radial-gradient(circle at bottom right, rgba(31, 41, 55, .10), transparent 35%), #f5f0e8;
        font-family: 'Segoe UI', sans-serif;
    }

    .landing-page {
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 50px 20px;
    }

    .landing-card {
        width: 100%;
        max-width: 1050px;
        padding: 70px 60px;
        border-radius: 36px;
        background: rgba(255, 255, 255, .72);
        border: 1px solid rgba(255, 255, 255, .85);
        box-shadow: 0 35px 90px rgba(92, 64, 39, .16);
        backdrop-filter: blur(18px);
        text-align: center;
    }

    .brand-logo {
        font-size: 86px;
        font-weight: 900;
        letter-spacing: -3px;
        color: #1f2937;
        margin-bottom: 10px;
    }

        .brand-logo span {
            color: #8b5e3c;
        }

    .brand-subtitle {
        font-size: 18px;
        letter-spacing: 5px;
        text-transform: uppercase;
        color: #9b6a3d;
        font-weight: 800;
        margin-bottom: 32px;
    }

    .hero-text {
        font-size: 28px;
        line-height: 1.45;
        font-weight: 700;
        color: #374151;
        max-width: 760px;
        margin: 0 auto 22px;
    }

    .hero-desc {
        color: #6b7280;
        font-size: 17px;
        line-height: 1.8;
        max-width: 650px;
        margin: 0 auto 38px;
    }

    .login-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px 44px;
        border-radius: 999px;
        background: #1f2937;
        color: white;
        font-weight: 800;
        text-decoration: none;
        box-shadow: 0 16px 35px rgba(31, 41, 55, .22);
        transition: .25s ease;
    }

        .login-btn:hover {
            background: #8b5e3c;
            color: white;
            transform: translateY(-3px);
        }

    .feature-grid {
        margin-top: 52px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    .feature-card {
        background: rgba(255, 255, 255, .72);
        border: 1px solid #eadfD2;
        border-radius: 22px;
        padding: 24px 18px;
        text-align: center;
        transition: .25s;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 18px 40px rgba(92, 64, 39, .12);
        }

    .feature-icon {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        margin: 0 auto 14px;
        background: #f1e4d4;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .feature-card h5 {
        font-size: 16px;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .feature-card p {
        font-size: 13px;
        color: #6b7280;
        margin: 0;
        line-height: 1.5;
    }

    .footer-note {
        margin-top: 42px;
        font-size: 13px;
        color: #9ca3af;
    }

    @@media (max-width: 900px) {
        .brand-logo {
            font-size: 56px;
        }

        .hero-text {
            font-size: 22px;
        }

        .feature-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .landing-card {
            padding: 45px 28px;
        }
    }
</style>

<div class="landing-page">

    <div class="landing-card">

        <div class="brand-logo">
            BREW <span>POS</span>
        </div>

        <div class="brand-subtitle">
            Building Reliable E-Web
        </div>

        <div class="hero-text">
            Modern Point of Sale System for Coffee Shop & F&B Business
        </div>

        <p class="hero-desc">
            Kelola transaksi, open bill, pembayaran, shift, status menu,
            dan laporan penjualan dalam satu sistem kasir berbasis web
            yang simpel, cepat, dan terstruktur.
        </p>

        <a href="/Users/Login" class="login-btn">
            Login to System →
        </a>

        <div class="feature-grid">

            <div class="feature-card">
                <div class="feature-icon">🧾</div>
                <h5>Open Bill</h5>
                <p>Simpan transaksi sementara untuk kebutuhan dine-in.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">☕</div>
                <h5>Sold Out</h5>
                <p>Atur status menu agar tidak salah input pesanan.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">🕘</div>
                <h5>Shift</h5>
                <p>Monitoring transaksi berdasarkan shift kasir.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h5>Report</h5>
                <p>Laporan transaksi dan produk terjual lebih rapi.</p>
            </div>

        </div>

        <div class="footer-note">
            BREW POS © 2026 — Simple, elegant, and reliable cashier system.
        </div>

    </div>

</div>