@model IEnumerable<BREW_POS.Models.Shift>

@{
    Layout = "_AdminLayout";
}

<h2 class="mb-4">Shift History</h2>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">

        <table class="table align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th>Shift Name</th>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Total Sales</th>
                    <th>Status</th>
                    <th>Detail</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ShiftName</td>

                        <td>@item.StartTime.ToString("dd MMM yyyy HH:mm")</td>

                        <td>
                            @(item.EndTime?.ToString("dd MMM yyyy HH:mm") ?? "-")
                        </td>

                        <td>
                            Rp @item.TotalSales.ToString("N0")
                        </td>

                        <td>
                            @if (item.IsClosed)
                            {
                                <span class="badge bg-secondary">Closed</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>

                        <td>
                            <a href="/Admin/ShiftDetail/@item.ShiftId"
                               class="btn btn-sm btn-primary">
                                Detail
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>