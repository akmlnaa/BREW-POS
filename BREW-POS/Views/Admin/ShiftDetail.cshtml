@model BREW_POS.Models.Shift

@{
    Layout = "_AdminLayout";

    decimal cashSales = ViewBag.CashSales ?? 0;
    decimal nonCashSales = ViewBag.NonCashSales ?? 0;
    decimal totalSales = ViewBag.TotalSales ?? 0;
    int totalTransactions = ViewBag.TotalTransactions ?? 0;
    int totalItemSold = ViewBag.TotalItemSold ?? 0;

    var payments = ViewBag.Payments as List<BREW_POS.Models.Payment>;
}

<h2 class="mb-4">Shift Detail</h2>

<div class="row mb-4">

    <div class="col-md-3 mb-3">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Shift Name</small>
            <h5>@Model.ShiftName</h5>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Total Sales</small>
            <h5>Rp @totalSales.ToString("N0")</h5>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Transactions</small>
            <h5>@totalTransactions</h5>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Item Sold</small>
            <h5>@totalItemSold</h5>
        </div>
    </div>

</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">

        <h5 class="mb-3">Shift Information</h5>

        <table class="table table-bordered mb-0">
            <tr>
                <th width="250">Start Time</th>
                <td>@Model.StartTime.ToString("dd MMM yyyy HH:mm")</td>
            </tr>

            <tr>
                <th>End Time</th>
                <td>@(Model.EndTime?.ToString("dd MMM yyyy HH:mm") ?? "-")</td>
            </tr>

            <tr>
                <th>Status</th>
                <td>
                    @if (Model.IsClosed)
                    {
                        <span class="badge bg-secondary">Closed</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </td>
            </tr>

            <tr>
                <th>Cash Sales</th>
                <td>Rp @cashSales.ToString("N0")</td>
            </tr>

            <tr>
                <th>Non-Cash Sales</th>
                <td>Rp @nonCashSales.ToString("N0")</td>
            </tr>
        </table>

    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <h5 class="mb-3">Payment List</h5>

        <div class="table-responsive">

            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Bill</th>
                        <th>Date</th>
                        <th>Method</th>
                        <th>Paid</th>
                        <th>Change</th>
                    </tr>
                </thead>

                <tbody>
                    @if (payments != null && payments.Any())
                    {
                        foreach (var item in payments)
                        {
                            <tr>
                                <td>@item.Bill?.BillName</td>
                                <td>@item.PaymentDate?.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@item.PaymentMethod</td>
                                <td>Rp @((item.PaidAmount ?? 0).ToString("N0"))</td>
                                <td>Rp @((item.ChangeAmount ?? 0).ToString("N0"))</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                Belum ada pembayaran pada shift ini.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>
</div>

<a href="/Admin/ShiftHistory"
   class="btn btn-secondary mt-3">
    Kembali
</a>