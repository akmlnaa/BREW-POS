@model IEnumerable<BREW_POS.Models.User>

@{
    Layout = "_AdminLayout";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>User Management</h2>

        <a href="/Admin/CreateUser"
           class="btn btn-dark">

            + Tambah User

        </a>

    </div>

    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead class="table-light">

                    <tr>
                        <th>Nama</th>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Aksi</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.FullName</td>

                            <td>@item.Username</td>

                            <td>

                                <span class="badge bg-dark">
                                    @item.Role
                                </span>

                            </td>

                            <td>

                                <a href="/Admin/EditUser/@item.UserId"
                                   class="btn btn-sm btn-warning">

                                    Edit

                                </a>

                                <button type="button"
                                        class="btn btn-sm btn-danger delete-user-btn"
                                        data-id="@item.UserId"
                                        data-name="@item.FullName">
                                    Delete
                                </button>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
<!-- MODAL DELETE USER -->
<div class="modal fade"
     id="deleteUserModal"
     tabindex="-1">

    <div class="modal-dialog modal-sm modal-dialog-centered">

        <div class="modal-content border-0 shadow-lg">

            <form asp-controller="Admin"
                  asp-action="DeleteUser"
                  method="post">

                <div class="modal-header">

                    <h5 class="modal-title">
                        Hapus User
                    </h5>

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>

                </div>

                <div class="modal-body text-center">

                    <input type="hidden"
                           id="deleteUserId"
                           name="id" />

                    <div style="font-size:50px">
                        ⚠️
                    </div>

                    <p class="mt-3">
                        Yakin ingin menghapus user berikut?
                    </p>

                    <strong id="deleteUserName"></strong>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Batal
                    </button>

                    <button type="submit"
                            class="btn btn-danger">
                        Hapus
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<script>

    document.addEventListener("click", function (e) {

        if (e.target.classList.contains("delete-user-btn")) {

            document.getElementById("deleteUserId").value =
                e.target.dataset.id;

            document.getElementById("deleteUserName").innerText =
                e.target.dataset.name;

            new bootstrap.Modal(
                document.getElementById("deleteUserModal")
            ).show();
        }

    });

</script>