@model IEnumerable<BREW_POS.Models.Bill>

@{
    Layout = "_AdminLayout";
}

<h2 class="mb-4">Sales Report</h2>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">

        <form method="get" class="row g-3 align-items-end">

            <div class="col-md-4">
                <label class="form-label">Start Date</label>
                <input type="date"
                       name="startDate"
                       value="@ViewBag.StartDate"
                       class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">End Date</label>
                <input type="date"
                       name="endDate"
                       value="@ViewBag.EndDate"
                       class="form-control" />
            </div>

            <div class="col-md-4">
                <button class="btn btn-dark w-100">
                    Filter
                </button>
            </div>

            <div class="mt-3">
                <a href="/Admin/ExportSalesReportExcel?startDate=@ViewBag.StartDate&endDate=@ViewBag.EndDate"
                   class="btn btn-success">
                    Export Excel
                </a>
            </div>
        </form>

    </div>
</div>

<div class="row mb-4">

    <div class="col-md-6">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Total Sales</small>
            <h3>Rp @ViewBag.TotalSales.ToString("N0")</h3>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card p-3 border-0 shadow-sm">
            <small class="text-muted">Total Transactions</small>
            <h3>@ViewBag.TotalTransactions</h3>
        </div>
    </div>

</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">

        <table class="table align-middle mb-0">

            <thead class="table-light">
                <tr>
                    <th>Bill Code</th>
                    <th>Bill Name</th>
                    <th>Date</th>
                    <th>Payment</th>
                    <th>Total</th>
                    <th>Receipt</th>
                    <th>Detail</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    var payment = item.Payments.FirstOrDefault();

                    <tr>
                        <td>@item.BillCode</td>

                        <td>@item.BillName</td>

                        <td>
                            @item.BillDate?.ToString("dd MMM yyyy HH:mm")
                        </td>

                        <td>
                            @(payment?.PaymentMethod ?? "-")
                        </td>

                        <td>
                            Rp @((item.GrandTotal ?? 0).ToString("N0"))
                        </td>

                        <td>
                            <a href="/Order/ReceiptBill/@item.BillId"
                               target="_blank"
                               class="btn btn-sm btn-outline-dark">
                                View
                            </a>
                        </td>

                        <td>
                            <a href="/Admin/TransactionDetail/@item.BillId"
                               class="btn btn-sm btn-primary">
                                Detail
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>